# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
# Both NEXT_PUBLIC_* values are safe to ship to the browser. The publishable
# key only grants what your RLS policies allow. NEVER put the service_role
# key here or anywhere in client-side code.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# Plaid — get these from https://dashboard.plaid.com/
# These are server-only (no NEXT_PUBLIC_ prefix). The access_token that
# Plaid issues per user is stored in Supabase (plaid_tokens table, RLS-locked).
PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_sandbox_or_production_secret

# "sandbox" (default) or "production". Plaid removed "development" in v41+.
PLAID_ENV=sandbox
